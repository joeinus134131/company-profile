# EmailJS (opsional) — untuk mengirim inquiry & newsletter ke email perusahaan.
# Daftar di https://www.emailjs.com , buat Email Service + Template, lalu isi nilai di bawah.
# Jika kosong, inquiry tetap tersimpan di localStorage (fallback).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Password login Admin (default: admin123 jika dikosongkan)
VITE_ADMIN_PASS=admin123
